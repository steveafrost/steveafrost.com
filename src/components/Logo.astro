---
/**
 * Frost crystal mark — asymmetric geometric facets matching the invoice logo.
 * Icon-only, no wordmark.
 */
---

<svg
  class="logo-mark"
  viewBox="0 0 72 72"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#eb7363"/>
      <stop offset="100%" stop-color="#f4a898"/>
    </linearGradient>
  </defs>

  <!-- Top-left facet -->
  <polygon points="32,0 52,16 32,32" fill="#eb7363"/>
  <!-- Top-right facet -->
  <polygon points="32,0 52,16 64,4" fill="#f4a898" opacity="0.85"/>
  <!-- Bottom-left facet -->
  <polygon points="0,28 20,44 32,32" fill="#f4a898" opacity="0.7"/>
  <!-- Center facet -->
  <polygon points="32,32 52,16 64,32 52,48" fill="url(#logo-grad)"/>
  <!-- Bottom facet -->
  <polygon points="32,32 20,44 32,60 52,48" fill="#eb7363" opacity="0.9"/>
  <!-- Bottom-right facet -->
  <polygon points="52,48 32,60 48,64 64,52" fill="#f4a898" opacity="0.65"/>
</svg>

<style>
  .logo-mark {
    width: 2rem;
    height: 2rem;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: drop-shadow(0 0 6px rgba(235, 115, 99, 0.15));
  }

  :global(.group:hover) .logo-mark {
    transform: scale(1.12) rotate(-4deg);
    filter: drop-shadow(0 0 10px rgba(235, 115, 99, 0.35));
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-mark {
      transition: none;
    }
    :global(.group:hover) .logo-mark {
      transform: none;
      filter: drop-shadow(0 0 6px rgba(235, 115, 99, 0.15));
    }
  }
</style>
